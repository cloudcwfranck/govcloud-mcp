# Required: Anthropic API key for Claude-powered tool responses
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the default site API base URL
# Used by bicep_analyze and bicep_remediate tools to call the CloudCraft site API
# Defaults to https://www.cloudcraftwithfranck.org
SITE_API_BASE=https://www.cloudcraftwithfranck.org
