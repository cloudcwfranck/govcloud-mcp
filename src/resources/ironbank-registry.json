  "pull_secret": {
    "registry": "registry1.dso.mil",
    "create_command": "kubectl create secret docker-registry registry1-creds --docker-server=registry1.dso.mil --docker-username=<USERNAME> --docker-password=<CLI_SECRET> -n <namespace>",
    "account_url": "https://login.dso.mil",
    "note": "Requires Platform One account with registry1 access. CLI Secret (not password) used for docker pull."
  },
  "cosign_verification": {
    "public_key_url": "https://ironbank.dso.mil/repomap/cosign.pub",
    "verify_command": "cosign verify --key https://ironbank.dso.mil/repomap/cosign.pub <image>:<tag>"
  }
