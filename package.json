{
  "name": "@cloudcraftwithfranck/govcloud-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing principal-level GovCloud compliance expertise. FedRAMP, NIST 800-53, Azure GCC High, Platform One, Big Bang, Chainguard.",
  "main": "dist/index.js",
  "bin": {
    "govcloud-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js && rm -rf dist/resources && cp -r src/resources dist/resources",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:node20": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:quality": "vitest run tests/quality",
    "test:integration": "vitest run tests/integration",
    "lint": "tsc --noEmit",
    "audit": "npm audit --audit-level high",
    "prepublishOnly": "npm run lint && npm run build && npm test && tsx scripts/prepublish-check.ts",
    "dry-run": "npm publish --dry-run"
  },
  "keywords": [
    "mcp",
    "fedramp",
    "nist-800-53",
    "azure",
    "govcloud",
    "devSecOps",
    "compliance",
    "platform-one",
    "bicep",
    "dod",
    "il4",
    "chainguard",
    "iron-bank",
    "ato"
  ],
  "author": "Franck Kengne <franck@cloudcraftwithfranck.org>",
  "license": "MIT",
  "homepage": "https://cloudcraftwithfranck.org/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudcwfranck/govcloud-mcp"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.6.1",
    "node-fetch": "^3.3.2",
    "tsx": "^4.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@vitest/coverage-v8": "^4.1.5",
    "nock": "^14.0.13",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
  ,
  "overrides": {
    "fast-uri": ">=3.1.2"
  }
}
